# Environment
NODE_ENV=development
PORT=3001

# Database
MONGODB_URI=mongodb://localhost:27017/hot-wheels-manager
# Para MongoDB Atlas (producción):
# MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/your-database?retryWrites=true&w=majority&appName=Cluster0

# JWT Secret (cambiar en producción - usar una cadena segura aleatoria)
JWT_SECRET=your-super-secure-jwt-secret-here-change-this-in-production

# Uploads
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpeg,jpg,png,webp

# CORS
FRONTEND_URL=http://localhost:5173

# Public Contact Form (SMTP)
# Required for POST /api/public/contact
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=josanmaes@gmail.com

# SMTP provider presets (uncomment and adapt one option)
# Gmail (App Password required)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-app-password
# CONTACT_FROM_EMAIL=tu-correo@gmail.com

# Outlook / Microsoft 365
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=tu-correo@outlook.com
# SMTP_PASS=tu-password-o-app-password
# CONTACT_FROM_EMAIL=tu-correo@outlook.com

# Mailgun
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@tu-dominio.mailgun.org
# SMTP_PASS=tu-smtp-password
# CONTACT_FROM_EMAIL=no-reply@tu-dominio.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Facebook Integration
# Para obtener estos valores, ve a https://developers.facebook.com
# 1. Crea una app de Facebook
# 2. Obtén el Page Access Token de tu página
# 3. Obtén el Page ID de tu página (ve a tu página > About > Page ID)
FACEBOOK_PAGE_ID=your-facebook-page-id
FACEBOOK_ACCESS_TOKEN=your-facebook-page-access-token

# eBay Browse API (register at https://developer.ebay.com)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# API Keys para futuras integraciones
# MERCADOLIBRE_API_KEY=
# SHIPPING_API_KEYS=
